SELECT t.id, t.created_at, t.input_snapshot, t.model_id, t.patient_id, t.prediction, t.probability, t.risk_level, t.threshold_used, t.user_id, p0.id, p0.age, p0.avg_glucose_level, p0.bmi, p0.created_at, p0.ever_married, p0.full_name, p0.gender, p0.heart_disease, p0.hypertension, p0.notes, p0.patient_code, p0.phone, p0.residence_type, p0.smoking_status, p0.updated_at, p0.user_id, p0.work_type, m.id, m.accuracy, m.auc_score, m.best_params, m.confusion_matrix, m.created_at, m.f1_score, m.imbalance_strategy, m.is_active, m.model_file_path, m.name, m.precision_score, m.recall_score, m.specificity, m.threshold, m.trained_at, m.training_duration, m.training_samples, m.version, u.id, u.created_at, u.email, u.full_name, u.is_active, u.last_login_at, u.password_hash, u.role, u.updated_at, u.username
FROM (
    SELECT p.id, p.created_at, p.input_snapshot, p.model_id, p.patient_id, p.prediction, p.probability, p.risk_level, p.threshold_used, p.user_id
    FROM predictions AS p
    ORDER BY p.created_at DESC
    LIMIT @__p_1 OFFSET @__p_0
) AS t
INNER JOIN patients AS p0 ON t.patient_id = p0.id
INNER JOIN ml_models AS m ON t.model_id = m.id
LEFT JOIN users AS u ON t.user_id = u.id
ORDER BY t.created_at DESC
