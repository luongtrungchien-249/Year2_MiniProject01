SELECT t.id AS "Id", p0.patient_code AS "PatientCode", CASE
    WHEN t.prediction = 1 THEN 'Nguy cơ Đột quỵ'
    ELSE 'Bình thường'
END AS "Result", t.probability AS "Probability", t.created_at AS "CreatedAt"
FROM (
    SELECT p.id, p.created_at, p.patient_id, p.prediction, p.probability
    FROM predictions AS p
    ORDER BY p.created_at DESC
    LIMIT @__p_0
) AS t
